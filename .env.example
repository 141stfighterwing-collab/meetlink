# MeetLink Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_USER=meetlink
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=meetlink
POSTGRES_PORT=5432

# ============================================
# Application
# ============================================
APP_PORT=3132
NEXT_PUBLIC_APP_URL=http://localhost:3132
NEXT_PUBLIC_APP_NAME=MeetLink
NODE_ENV=development

# ============================================
# Database URL
# ============================================
# For local development:
DATABASE_URL="postgresql://meetlink:your_secure_password_here@localhost:5432/meetlink?schema=public"
# For Docker deployment:
# DATABASE_URL="postgresql://meetlink:your_secure_password_here@postgres:5432/meetlink"

# ============================================
# Authentication & Security
# ============================================
# Generate a secure secret: openssl rand -hex 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3132
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# ============================================
# Redis Cache (Optional)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redis_secure_password

# ============================================
# Email Configuration (Optional)
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@yourdomain.com

# ============================================
# OAuth Providers (Optional)
# ============================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft/Azure AD
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ============================================
# Video Conferencing (Optional)
# ============================================
# Zoom
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Microsoft Teams
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=

# ============================================
# SMS Notifications (Optional)
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================
# Logging & Auditing
# ============================================
LOG_LEVEL=info
AUDIT_LOG_ENABLED=true

# ============================================
# Security Settings
# ============================================
CORS_ORIGINS=http://localhost:3132
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
